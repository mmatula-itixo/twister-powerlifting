---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rules & Scoring — Twister Powerlifting">
  <div class="page-content">
    <div class="rules-card">

      <!-- Page header -->
      <div class="page-header">
        <div class="page-badge">Competition Guidelines</div>
        <h1 class="page-title">Rules &amp; Scoring</h1>
        <p class="page-subtitle">
          Official IPF-compliant regulations for the Twister Powerlifting Competition 2026
        </p>
      </div>

      <div class="sections">

        <!-- Competition Format -->
        <section class="rule-section">
          <h2 class="section-title">
            <div class="section-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
            </div>
            Competition Format
          </h2>
          <p class="section-text">
            The competition follows the IPF (International Powerlifting Federation) rules and regulations.
            Each lifter will perform three attempts for each of the three main lifts in the following order:
          </p>
          <ol class="ordered-list">
            <li>Squat</li>
            <li>Bench Press</li>
            <li>Deadlift</li>
          </ol>
        </section>

        <!-- Weight Classes -->
        <section class="rule-section">
          <h2 class="section-title">
            <div class="section-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
              </svg>
            </div>
            Weight Classes
          </h2>
          <div class="weight-grid">
            <div class="weight-card">
              <h3 class="weight-title">Men's Categories</h3>
              <ul class="weight-list">
                <li>&bull; 59 kg</li>
                <li>&bull; 66 kg</li>
                <li>&bull; 74 kg</li>
                <li>&bull; 83 kg</li>
                <li>&bull; 93 kg</li>
                <li>&bull; 105 kg</li>
                <li>&bull; 120 kg</li>
                <li>&bull; 120+ kg</li>
              </ul>
            </div>
            <div class="weight-card">
              <h3 class="weight-title">Women's Categories</h3>
              <ul class="weight-list">
                <li>&bull; 47 kg</li>
                <li>&bull; 52 kg</li>
                <li>&bull; 57 kg</li>
                <li>&bull; 63 kg</li>
                <li>&bull; 69 kg</li>
                <li>&bull; 76 kg</li>
                <li>&bull; 84 kg</li>
                <li>&bull; 84+ kg</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Scoring System -->
        <section class="rule-section">
          <h2 class="section-title">
            <div class="section-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            Scoring System
          </h2>
          <div class="scoring-list">
            <div class="scoring-card">
              <h3 class="scoring-label">
                <span class="scoring-num">1</span>
                Total Score
              </h3>
              <p>
                Your total score is the sum of your best successful attempt for each of the three lifts
                (Squat + Bench Press + Deadlift). The competitor with the highest total in their weight
                class wins.
              </p>
            </div>
            <div class="scoring-card">
              <h3 class="scoring-label">
                <span class="scoring-num">2</span>
                Wilks Score
              </h3>
              <p>
                The Wilks formula is used to compare lifters of different body weights. The overall
                best lifter award is determined by the highest Wilks coefficient across all weight classes.
              </p>
            </div>
            <div class="scoring-card">
              <h3 class="scoring-label">
                <span class="scoring-num">3</span>
                Attempt Selection
              </h3>
              <p>
                Lifters must declare their opening weight before the competition. Each subsequent attempt
                must be at least 2.5 kg heavier than the previous successful attempt. You may pass on
                attempts if needed.
              </p>
            </div>
          </div>
        </section>

        <!-- Lift Requirements -->
        <section class="rule-section">
          <h2 class="section-title">
            <div class="section-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            Lift Requirements
          </h2>
          <div class="lift-list">
            <div class="lift-item">
              <h3 class="lift-name">Squat</h3>
              <ul class="disc-list">
                <li>The top of the thighs at the hip joint must be lower than the top of the knees</li>
                <li>Wait for the "squat" and "rack" commands from the head judge</li>
                <li>The lifter must stand erect with knees locked at completion</li>
              </ul>
            </div>
            <div class="lift-item">
              <h3 class="lift-name">Bench Press</h3>
              <ul class="disc-list">
                <li>The bar must touch the chest</li>
                <li>Wait for the "press" and "rack" commands from the head judge</li>
                <li>Buttocks must remain in contact with the bench</li>
                <li>Feet must remain flat on the floor</li>
              </ul>
            </div>
            <div class="lift-item">
              <h3 class="lift-name">Deadlift</h3>
              <ul class="disc-list">
                <li>The lifter must stand erect with knees locked and shoulders back</li>
                <li>Wait for the "down" command from the head judge before lowering the bar</li>
                <li>Supporting the bar on the thighs is not permitted</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Equipment Regulations -->
        <section class="rule-section">
          <h2 class="section-title">
            <div class="section-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            Equipment Regulations
          </h2>
          <ul class="disc-list">
            <li>Approved lifting singlet or appropriate athletic wear</li>
            <li>Non-supportive lifting belt (maximum 10cm width)</li>
            <li>Wrist wraps (maximum 1m length)</li>
            <li>Knee sleeves (non-supportive, maximum 30cm length)</li>
            <li>Chalk is permitted</li>
            <li>No lifting suits or supportive gear in raw division</li>
          </ul>
        </section>

        <!-- Important Notice banner -->
        <div class="notice-banner">
          <div class="notice-blob"></div>
          <div class="notice-inner">
            <div class="notice-icon">
              <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="notice-title">Important Notice</h3>
              <p class="notice-text">
                All lifters must attend the mandatory rules briefing 30 minutes before the competition start time. Failure to attend may result in disqualification.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout>

<style>
  .page-content {
    max-width: 64rem;
    margin: 0 auto;
    padding: 3rem 1rem;
  }
  @media (min-width: 640px)  { .page-content { padding: 3rem 1.5rem; } }
  @media (min-width: 1024px) { .page-content { padding: 3rem 2rem; } }

  .rules-card {
    background: var(--color-bg-white);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-2xl);
    padding: 1.5rem;
    border: 1px solid var(--color-border-100);
  }
  @media (min-width: 640px) { .rules-card { padding: 3rem; } }

  /* Page header */
  .page-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: linear-gradient(to right, #004c88, #0066bb);
    color: #fff;
    border-radius: var(--radius-full);
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3rem);
    background: linear-gradient(to right, #004c88, #0066bb);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
  }

  .page-subtitle {
    color: var(--color-text-600);
    max-width: 32rem;
    margin: 0 auto;
  }

  /* Sections */
  .sections { display: flex; flex-direction: column; gap: 2.5rem; }

  .rule-section {
    background: linear-gradient(to right, #eff6ff, transparent);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    border-left: 4px solid #004c88;
  }

  .section-title {
    font-size: 1.5rem;
    color: #004c88;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .section-icon {
    padding: 0.5rem;
    background: #004c88;
    border-radius: 0.5rem;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .section-text {
    color: var(--color-text-700);
    margin-bottom: 1rem;
  }

  .ordered-list {
    list-style: decimal;
    list-style-position: inside;
    color: var(--color-text-700);
    margin-left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .disc-list {
    list-style: disc;
    list-style-position: inside;
    color: var(--color-text-700);
    margin-left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  /* Weight classes */
  .weight-grid {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 768px) { .weight-grid { grid-template-columns: 1fr 1fr; } }

  .weight-card {
    background: var(--color-bg-white);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border-100);
  }

  .weight-title {
    font-weight: 700;
    color: #004c88;
    font-size: 1.125rem;
    margin-bottom: 1rem;
  }

  .weight-list {
    list-style: none;
    color: var(--color-text-700);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  /* Scoring */
  .scoring-list { display: flex; flex-direction: column; gap: 1rem; }

  .scoring-card {
    background: var(--color-bg-white);
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border-100);
    color: var(--color-text-700);
  }

  .scoring-label {
    font-weight: 700;
    color: #004c88;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .scoring-num {
    width: 2rem;
    height: 2rem;
    background: linear-gradient(135deg, #004c88, #0066bb);
    color: #fff;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    flex-shrink: 0;
  }

  /* Lift requirements */
  .lift-list { display: flex; flex-direction: column; gap: 1rem; }

  .lift-item { color: var(--color-text-700); }

  .lift-name {
    font-weight: 700;
    color: #004c88;
    margin-bottom: 0.5rem;
  }

  /* Notice banner */
  .notice-banner {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #004c88, #0066bb);
    color: #fff;
    padding: 2rem;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    margin-top: 2rem;
  }

  .notice-blob {
    position: absolute;
    top: 0;
    right: 0;
    width: 8rem;
    height: 8rem;
    background: rgba(255,255,255,0.1);
    border-radius: var(--radius-full);
    transform: translate(50%, -50%);
  }

  .notice-inner {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .notice-icon {
    padding: 0.75rem;
    background: rgba(255,255,255,0.2);
    border-radius: var(--radius-lg);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .notice-title {
    font-weight: 700;
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }

  .notice-text { color: #bfdbfe; }
</style>
