---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Twister Powerlifting Competition 2026">
  <div class="page-content">

    <!-- Hero -->
    <div class="hero">
      <div class="hero-gradient"></div>
      <div class="hero-pattern"></div>
      <div class="hero-body">
        <div class="hero-badge">June 15, 2026 &bull; Twister Sports Complex</div>
        <h1 class="hero-title">
          Twister Powerlifting<br />Competition 2026
        </h1>
        <p class="hero-subtitle">Push Your Limits. Set New Records. Join the Elite.</p>
        <div class="hero-ctas">
          <a href="/registration" class="btn-primary">Register Now</a>
          <a href="/rules" class="btn-outline">View Rules</a>
        </div>
      </div>
    </div>

    <!-- Info grid -->
    <div class="info-grid">
      <!-- Event Details card -->
      <div class="card">
        <div class="card-header">
          <div class="icon-box">
            <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h2 class="card-title">Event Details</h2>
        </div>
        <div class="detail-list">
          <div class="detail-row">
            <div class="detail-icon-wrap">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <div class="detail-label">Date</div>
              <div class="detail-value">June 15, 2026</div>
            </div>
          </div>
          <div class="detail-row">
            <div class="detail-icon-wrap">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <div class="detail-label">Time</div>
              <div class="detail-value">9:00 AM - 6:00 PM</div>
            </div>
          </div>
          <div class="detail-row">
            <div class="detail-icon-wrap">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <div class="detail-label">Venue</div>
              <div class="detail-value">Twister Sports Complex</div>
              <div class="detail-sub">123 Power Street, Athletic City</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Competition Info card -->
      <div class="card">
        <div class="card-header">
          <div class="icon-box">
            <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h2 class="card-title">Competition Info</h2>
        </div>
        <ul class="checklist">
          <li class="checklist-item">
            <svg class="check-icon" fill="currentColor" viewBox="0 0 20 20" width="20" height="20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Open to all skill levels - Novice to Elite</span>
          </li>
          <li class="checklist-item">
            <svg class="check-icon" fill="currentColor" viewBox="0 0 20 20" width="20" height="20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Three main lifts: Squat, Bench Press, Deadlift</span>
          </li>
          <li class="checklist-item">
            <svg class="check-icon" fill="currentColor" viewBox="0 0 20 20" width="20" height="20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Multiple weight classes for men and women</span>
          </li>
          <li class="checklist-item">
            <svg class="check-icon" fill="currentColor" viewBox="0 0 20 20" width="20" height="20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>IPF-approved equipment and judging</span>
          </li>
          <li class="checklist-item">
            <svg class="check-icon" fill="currentColor" viewBox="0 0 20 20" width="20" height="20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Awards for top performers in each category</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="cta-section">
      <div class="cta-blob cta-blob-tr"></div>
      <div class="cta-blob cta-blob-bl"></div>
      <div class="cta-content">
        <h2 class="cta-title">Ready to Compete?</h2>
        <p class="cta-text">
          Registration closes on June 1, 2026. Secure your spot now and become part of powerlifting excellence!
        </p>
        <div class="hero-ctas">
          <a href="/registration" class="btn-primary">Register Now</a>
          <a href="/rules" class="btn-outline">View Rules</a>
        </div>
      </div>
    </div>

  </div>
</Layout>

<style>
  .page-content {
    max-width: 80rem;
    margin: 0 auto;
    padding: 3rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  @media (min-width: 640px)  { .page-content { padding: 3rem 1.5rem; } }
  @media (min-width: 1024px) { .page-content { padding: 3rem 2rem; } }

  /* ---- Hero ---- */
  .hero {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-2xl);
    background: #fff;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #004c88 0%, #0066bb 50%, #004c88 100%);
    opacity: 0.95;
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHZpZXdCb3g9IjAgMCA2MCA2MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZyBmaWxsPSJub25lIiBmaWxsLXJ1bGU9ImV2ZW5vZGQiPjxnIGZpbGw9IiNmZmYiIGZpbGwtb3BhY2l0eT0iMC4wNSI+PHBhdGggZD0iTTM2IDEzNGgxMnYxMkgzNnoiLz48L2c+PC9nPjwvc3ZnPg==");
    opacity: 0.3;
  }

  .hero-body {
    position: relative;
    padding: 5rem 1.5rem;
    text-align: center;
  }
  @media (min-width: 640px) { .hero-body { padding: 7rem 3rem; } }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    border-radius: var(--radius-full);
    color: rgba(255,255,255,0.9);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2.25rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    color: #bfdbfe;
    margin-bottom: 2rem;
    max-width: 32rem;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }
  @media (min-width: 640px) {
    .hero-ctas { flex-direction: row; }
  }

  .btn-primary {
    background: #fff;
    color: #004c88;
    padding: 1rem 2rem;
    border-radius: var(--radius-lg);
    font-weight: 600;
    font-size: 1rem;
    box-shadow: var(--shadow-lg);
    transition: background 0.2s, box-shadow 0.2s, transform 0.2s;
    display: inline-block;
    text-align: center;
  }
  .btn-primary:hover {
    background: #eff6ff;
    box-shadow: var(--shadow-xl);
    transform: scale(1.05);
  }

  .btn-outline {
    background: transparent;
    border: 2px solid #fff;
    color: #fff;
    padding: 1rem 2rem;
    border-radius: var(--radius-lg);
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.2s;
    display: inline-block;
    text-align: center;
  }
  .btn-outline:hover { background: rgba(255,255,255,0.1); }

  /* ---- Info grid ---- */
  .info-grid {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 768px) { .info-grid { grid-template-columns: 1fr 1fr; } }

  .card {
    background: var(--color-bg-white);
    padding: 2rem;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--color-border-100);
    transition: box-shadow 0.2s;
  }
  .card:hover { box-shadow: var(--shadow-xl); }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .icon-box {
    padding: 0.75rem;
    background: linear-gradient(135deg, #004c88, #0066bb);
    border-radius: var(--radius-lg);
    color: #fff;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text-900);
  }

  /* Detail rows */
  .detail-list { display: flex; flex-direction: column; gap: 1rem; }

  .detail-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem;
    background: linear-gradient(to right, #eff6ff, transparent);
    border-radius: var(--radius-lg);
  }

  .detail-icon-wrap {
    padding: 0.5rem;
    background: #fff;
    border-radius: 0.5rem;
    box-shadow: var(--shadow-sm);
    color: #004c88;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .detail-label {
    font-size: 0.875rem;
    color: var(--color-text-500);
  }

  .detail-value {
    font-weight: 600;
    color: var(--color-text-900);
  }

  .detail-sub {
    font-size: 0.875rem;
    color: var(--color-text-600);
  }

  /* Checklist */
  .checklist { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }

  .checklist-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 0.5rem;
    transition: background 0.15s;
    color: var(--color-text-700);
  }
  .checklist-item:hover { background: rgba(239,246,255,0.5); }

  .check-icon {
    color: #004c88;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  /* ---- Bottom CTA ---- */
  .cta-section {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #004c88, #0066bb);
    padding: 2rem;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    color: #fff;
  }
  @media (min-width: 640px) { .cta-section { padding: 3rem; } }

  .cta-blob {
    position: absolute;
    background: rgba(255,255,255,0.1);
    border-radius: var(--radius-full);
  }
  .cta-blob-tr { width: 16rem; height: 16rem; top: 0; right: 0; transform: translate(50%, -50%); }
  .cta-blob-bl { width: 12rem; height: 12rem; bottom: 0; left: 0; transform: translate(-50%, 50%); }

  .cta-content { position: relative; text-align: center; }

  .cta-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .cta-text {
    font-size: 1.125rem;
    color: #bfdbfe;
    margin-bottom: 2rem;
    max-width: 32rem;
    margin-left: auto;
    margin-right: auto;
  }
</style>
